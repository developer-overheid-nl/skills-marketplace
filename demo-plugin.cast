[0.000, "o", "                          \u001b[49m\r\r\n\r\r\n\u001b[38;2;255;255;255mвҸә\u001b[1C\u001b[39mHere's\u001b[1Ca\u001b[1Cquick\u001b[1Coverview\u001b[1Cof\u001b[1Cbuilding\u001b[1Can\u001b[1CAPI:\r\r\n\r\r\n\u001b[2C\u001b[1m1.\u001b[1CChoose\u001b[1Cyour\u001b[1Cstack\u001b[22m\r\r\n\r\r\n\u001b[2C-\u001b[1C\u001b[1mPython\u001b[22m:\u001b[1CFastAPI,\u001b[1CFlask,\u001b[1CDjango\u001b[1CREST\u001b[1CFramework\r\r\n\u001b[2C-\u001b[1C\u001b[1mNode.js\u001b[22m:\u001b[1CExpress,\u001b[1CFastify,\u001b[1CHono\r\r\n\u001b[2C-\u001b[1C\u001b[1mGo\u001b[22m:\u001b[1Cnet/http,\u001b[1CGin,\u001b[1CEcho\r\r\n\u001b[2C-\u001b[1C\u001b[1mJava\u001b[22m:\u001b[1CSpring\u001b[1CBoot\r\r\n\r\r\n\u001b[2C\u001b[1m2.\u001b[1CBasic\u001b[1Cstructure\u001b[1C(FastAPI\u001b[1Cexample)\u001b[22m\r\r\n\r\r\n\u001b[2C\u001b[34mfrom\u001b[1C\u001b[39mfastapi\u001b[1C\u001b[34mimport\u001b[1C\u001b[39mFastAPI\r\r\n\r\r\n\u001b[2Capp\u001b[1C=\u001b[1CFastAPI()\r\r\n\r\r\n\u001b[2C\u001b[90m@app.get(\u001b[31m\"/items/{item_id}\"\u001b[90m)\u001b[39m\r\r\n\u001b[2C\u001b[34mdef\u001b[33m get_item(item_id:\u001b[1C\u001b[36mint\u001b[33m):\u001b[39m\r\r\n\u001b[6C\u001b[34mreturn\u001b[1C\u001b[39m{\u001b[31m\"item_id\"\u001b[39m:\u001b[1Citem_id,\u001b[1C\u001b[31m\"name\"\u001b[39m:\u001b[1C\u001b[31m\"Example\"\u001b[39m}\r\r\n\r\r\n\u001b[2C\u001b[90m@app.post(\u001b[31m\"/items\"\u001b[90m)\u001b[39m\r\r\n\u001b[2C\u001b[34mdef\u001b[33m create_item(item:\u001b[1C\u001b[36mdict\u001b[33m):\u001b[39m\r\r\n\u001b[6C\u001b[34mreturn\u001b[1C\u001b[39m{\u001b[31m\"created\"\u001b[39m:\u001b[1Citem}\r\r\n\r\r\n\u001b[2CRun\u001b[1Cwith:\u001b[1C\u001b[38;2;177;185;249"]
