[0.024, "o", "\u001b[?2026h\r\u001b[7A\u001b[38;2;255;255;255mвҸә\u001b[1C\u001b[39mHere's a quick overview of building\u001b[1Can\u001b[1CAPI:\r\u001b[2B  \u001b[1m1. Choose your stack\u001b[22m                                                                             \r\u001b[1B   \r\u001b[1B  - \u001b[1mPython\u001b[22m: FastAPI, Flask, Django REST Framework                                                  \r\u001b[2C\u001b[1B- \u001b[1mNode.js\u001b[22m: Express, Fastify,\u001b[1CHono\u001b[44C                  \r\u001b[2C\u001b[1B- \u001b[1mGo\u001b[22m: net/http, Gin, Echo                    \r\r\n\u001b[2C-\u001b[1C\u001b[1mJava\u001b[22m:\u001b[1CSpring\u001b[1CBoot\r\r\n\r\r\n\u001b[2C\u001b[1m2.\u001b[1CBasic\u001b[1Cstructure\u001b[1C(FastAPI\u001b[1Cexample)\u001b[22m\r\r\n\r\r\n\u001b[2C\u001b[34mfrom\u001b[1C\u001b[39mfastapi\u001b[1C\u001b[34mimport\u001b[1C\u001b[39mFastAPI\r\r\n\r\r\n\u001b[2Capp\u001b[1C=\u001b[1CFastAPI()\r\r\n\r\r\n\u001b[2C\u001b[90m@app.get(\u001b[31m\"/items/{item_id}\"\u001b[90m)\u001b[39m\r\r\n\u001b[2C\u001b[34mdef\u001b[33m get_item(item_id:\u001b[1C\u001b[36mint\u001b[33m):\u001b[39m\r\r\n\u001b[6C\u001b[34mreturn\u001b[1C\u001b[39m{\u001b[31m\"item_id\"\u001b[39m:\u001b[1Citem_id,\u001b[1C\u001b[31m\"name\"\u001b[39m:\u001b[1C\u001b[31m\"Example\"\u001b[39m}\r\r\n\r\r\n\u001b[2C\u001b[90m@app.post(\u001b[31m\"/items\"\u001b[90m)\u001b[39m\r\r\n\u001b[2C\u001b[34mdef\u001b[33m create_item(item:\u001b[1C\u001b[36mdict\u001b[33m):\u001b[39m\r\r\n\u001b[6C\u001b[34m"]
[0.000, "o", "return\u001b[1C\u001b[39m{\u001b[31m\"created\"\u001b[39m:\u001b[1Citem}\r\r\n\r\r\n\u001b[2CRun\u001b[1Cwith:\u001b[1C\u001b[38;2;177;185;249muv\u001b[1Crun\u001b[1Cuvicorn\u001b[1Cmain:app\u001b[1C--reload\u001b[39m\r\r\n\r\r\n\u001b[2C\u001b[1m3.\u001b[1CKey\u001b[1Cdesign\u001b[1Cprinciples\u001b[22m\r\r\n\r\r\n\u001b[2C-\u001b[1C\u001b[1mUse\u001b[1CRESTful\u001b[1Cconventions\u001b[22m:\u001b[1Cnouns\u001b[1Cfor\u001b[1Cresources\u001b[1C(\u001b[38;2;177;185;249m/users\u001b[39m,\u001b[1C\u001b[38;2;177;185;249m/orders\u001b[39m),\u001b[1CHTTP\u001b[1Cverbs\u001b[1Cfor\u001b[1Cactions\u001b[1C(GET,\r\r\n\u001b[2CPOST,\u001b[1CPUT,\u001b[1CDELETE)\r\r\n\u001b[2C-\u001b[1C\u001b[1mVersion\u001b[1Cyour\u001b[1CAPI\u001b[22m:\u001b[1C\u001b[38;2;177;185;249m/api/v1/users\u001b[39m\r\r\n\u001b[2C-\u001b[1C\u001b[1mReturn\u001b[1Cproper\u001b[1Cstatus\u001b[1Ccodes\u001b[22m:\u001b[1C200\u001b[1COK,\u001b[1C201\u001b[1CCreated,\u001b[1C404\u001b[1CNot\u001b[1CFound,\u001b[1C422\u001b[1CValidation\u001b[1CError\r\r\n\u001b[2C-\u001b[1C\u001b[1mUse\u001b[1CJSON\u001b[1C\u001b[22mfor\u001b[1Crequest/response\u001b[1Cbodies\r\r\n\u001b[2C-\u001b[1C\u001b[1mValidate\u001b[1Cinput\u001b[1C\u001b[22mat\u001b[1Cthe\u001b[1Cboundary\r\r\n\u001b[2C-\u001b[1C\u001b[1mDocument\u001b[1Cwith\u001b[1COpenAPI/Swagger\u001b[1C\u001b[22m(FastAPI\u001b[1Cdoes\u001b[1Cthis\u001b[1Cautomatically)\r\r\n\r\r\n\u001b[2C\u001b[1m4.\u001b[1CEssential\u001b[1Cfeatures\u001b[1Cto\u001b[1Cadd\u001b[22m\r\r\n\r\r\n\u001b[2C-\u001b[1C\u001b[1mAuthentication\u001b[22m:\u001b[1CAPI\u001b[1Ckeys,\u001b[1COAuth2,\u001b[1Cor\u001b[1CJWT\r"]
[0.000, "o", "\r\n\u001b[2C-\u001b[1C\u001b[1mRate\u001b[1Climiting\u001b[22m:\u001b[1CProtect\u001b[1Cagainst\u001b[1Cabuse\r\r\n\u001b[2C-\u001b[1C\u001b[1mError\u001b[1Chandling\u001b[22m:\u001b[1CConsistent\u001b[1Cerror\u001b[1Cresponse\u001b[1Cformat\r\r\n\u001b[2C-\u001b[1C\u001b[1mLogging\u001b[22m:\u001b[1CRequest/response\u001b[1Clogging\u001b[1Cfor\u001b[1Cdebugging\r\r\n\u001b[2C-\u001b[1C\u001b[1mCORS\u001b[22m:\u001b[1CIf\u001b[1Ccalled\u001b[1Cfrom\u001b[1Cbrowsers\r\r\n\r\r\n\u001b[2C\u001b[1m5.\u001b[1CTesting\u001b[22m\r\r\n\r\r\n\u001b[2C\u001b[34mfrom\u001b[1C\u001b[39mfastapi.testclient\u001b[1C\u001b[34mimport\u001b[1C\u001b[39mTestClient\r\r\n\r\r\n\u001b[2Cclient\u001b[1C=\u001b[1CTestClient(app)\r\r\n\r\r\n\u001b[2C\u001b[34mdef\u001b[33m test_get_item():\u001b[39m\r\r\n\u001b[6Cresponse\u001b[1C=\u001b[1Cclient.get(\u001b[31m\"/items/1\"\u001b[39m)\r\r\n\u001b[6C\u001b[34massert\u001b[1C\u001b[39mresponse.status_code\u001b[1C==\u001b[1C\u001b[32m200\u001b[39m\r\r\n\r\r\n\u001b[2CWant\u001b[1Cme\u001b[1Cto\u001b[1Cscaffold\u001b[1Ca\u001b[1Cspecific\u001b[1CAPI\u001b[1Cproject\u001b[1Cfor\u001b[1Cyou?\u001b[1CIf\u001b[1Cso,\u001b[1Clet\u001b[1Cme\u001b[1Cknow\u001b[1Cthe\u001b[1Clanguage/framework\u001b[1Cand\r\r\n\u001b[3Cwhat\u001b[1Cthe\u001b[1CAPI\u001b[1Cshould\u001b[1Cdo.\r\r\n\r\r\n\u001b[38;2;215;119;87mвң¶\u001b[1C\u001b[38;2;228;145;113mContemplatingвҖҰ\u001b[38;2;215;119;87m \u001b[38;2;153;153;153m(running\u001b[1Cstop\u001b[1Chook)\u001b[39m\r\r\n\r\r\n\u001b[38;2;136;136;136mв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ"]
