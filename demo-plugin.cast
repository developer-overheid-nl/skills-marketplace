[0.000, "o", "l_next):\u001b[39m\r\r\n\u001b[6Cresponse\u001b[1C=\u001b[1C\u001b[34mawait\u001b[1C\u001b[39mcall_next(request)\r\r\n\u001b[6Cresponse.headers[\u001b[31m\"API-Version\"\u001b[39m]\u001b[1C=\u001b[1C\u001b[31m\"1.0.0\"\u001b[39m\r\r\n\u001b[6Cresponse.headers[\u001b[31m\"Cache-Control\"\u001b[39m]\u001b[1C=\u001b[1C\u001b[31m\"no-store\"\u001b[39m\r\r\n\u001b[6Cresponse.headers[\u001b[31m\"Strict-Transport-Security\"\u001b[39m]\u001b[1C=\u001b[1C\u001b[31m\"max-age=31536000\"\u001b[39m\r\r\n\u001b[6Cresponse.headers[\u001b[31m\"X-Content-Type-Options\"\u001b[39m]\u001b[1C=\u001b[1C\u001b[31m\"nosniff\"\u001b[39m\r\r\n\u001b[6Cresponse.headers[\u001b[31m\"X-Frame-Options\"\u001b[39m]\u001b[1C=\u001b[1C\u001b[31m\"DENY\"\u001b[39m\r\r\n\u001b[6Cresponse.headers[\u001b[31m\"Content-Security-Policy\"\u001b[39m]\u001b[1C=\u001b[1C\u001b[31m\"frame-ancestors\u001b[1C'none'\"\u001b[39m\r\r\n\u001b[6C\u001b[34mreturn\u001b[1C\u001b[39mresponse\r\r\n\r\r\n\u001b[2C\u001b[90m@app.exception_handler(HTTPException)\u001b[39m\r\r\n\u001b[2C\u001b[34masync\u001b[1Cdef\u001b[33m problem_json_handler(request:\u001b[1CRequest,\u001b[1Cexc:\u001b[1CHTTPException):\u001b[39m\r\r\n\u001b[6C\u001b[34mreturn\u001b[1C\u001b[39mJSONResponse(\r\r\n\u001b[10Cstatus_code=exc.status_code,\r\r\n\u001b[10Ccontent={\r\r\n\u001b[14C\u001b[31m\"type\"\u001b[39m:\u001b[1C\u001b[31mf\"https://api.example.com/errors/{exc.status_code}\"\u001b[39m,\r\r\n\u001b[14C\u001b[31m\"title\"\u001b[39m:\u001b[1C\u001b[36mstr\u001b[39m(exc.d"]
