[0.018, "o", "\u001b[?2026h\r\u001b[7A\u001b[38;2;255;255;255mвҸә\u001b[1C\u001b[39mGreat question! Building a government\u001b[1CAPI\u001b[1C(especially\u001b[1Cin\u001b[1Cthe\u001b[1CDutch\u001b[1Ccontext)\u001b[1Ccomes\u001b[1Cwith\u001b[1Cspecific\u001b[1Cmandatory\u001b[1Cstandards.\u001b[1CHere's\u001b[1Cwhat\u001b[1Cyou\u001b[1Cneed\u001b[1Cto\u001b[1Cknow:\r\u001b[2B  \u001b[1mKey Differences from Regular APIs\u001b[22m                                                                                                                       \r\u001b[1B   \r\u001b[1B  Government APIs in the Netherlands must follow the \u001b[1mAPI Design Rules (ADR)\u001b[22m вҖ” mandatory under the \"pas-toe-of-leg-uit\" regime of Forum Standaardisatie.   \r\u001b[2C\u001b[1B                              \r\u001b[2C\u001b[1B\u001b[1mMust-Have Requirements\u001b[22m                       \r\r\n\r\r\n\u001b[2C\u001b[1m1.\u001b[1CURI\u001b[1CDesign\u001b[22m\r\r\n\r\r\n\u001b[2C-\u001b[1C\u001b[1mKebab-case\u001b[1C\u001b[22mpaths:\u001b[1C\u001b[38;2;177;185;249m/mijn-documenten\u001b[1C\u001b[39m(not\u001b[1C\u001b[38;2;177;185;249m/mijnDocumenten\u001b[39m)\r\r\n\u001b[2C-\u001b[1C\u001b[1mcamelCase\u001b[1C\u001b[22mquery\u001b[1Cparams:\u001b[1C\u001b[38;2;177;185;249m?sortOrder=desc\u001b[39m\r\r\n\u001b[2C-\u001b[1CMajor\u001b[1Cversion\u001b[1Cin\u001b[1CURI:\u001b[1C\u001b[38;2;177;185;249"]
[0.000, "o", "m/v1/resources\u001b[39m\r\r\n\u001b[2C-\u001b[1CNo\u001b[1Ctrailing\u001b[1Cslashes,\u001b[1Cno\u001b[1Cfile\u001b[1Cextensions\r\r\n\r\r\n\u001b[2C\u001b[1m2.\u001b[1CError\u001b[1CResponses\u001b[1CвҖ”\u001b[1C\u001b[38;2;177;185;249mapplication/problem+json\u001b[39m (RFC\u001b[1C9457)\u001b[22m\r\r\n\r\r\n\u001b[2C{\r\r\n\u001b[4C\u001b[36m\"type\"\u001b[39m:\u001b[1C\u001b[31m\"https://api.example.com/errors/insufficient-funds\"\u001b[39m,\r\r\n\u001b[4C\u001b[36m\"title\"\u001b[39m:\u001b[1C\u001b[31m\"Insufficient\u001b[1CFunds\"\u001b[39m,\r\r\n\u001b[4C\u001b[36m\"status\"\u001b[39m:\u001b[1C\u001b[32m422\u001b[39m,\r\r\n\u001b[4C\u001b[36m\"detail\"\u001b[39m:\u001b[1C\u001b[31m\"Your\u001b[1Ccurrent\u001b[1Cbalance\u001b[1Cis\u001b[1C30,\u001b[1Cbut\u001b[1Cthat\u001b[1Ccosts\u001b[1C50.\"\u001b[39m,\r\r\n\u001b[4C\u001b[36m\"instance\"\u001b[39m:\u001b[1C\u001b[31m\"/account/12345/transactions/abc\"\u001b[39m\r\r\n\u001b[2C}\r\r\n\r\r\n\u001b[2C\u001b[1m3.\u001b[1CMandatory\u001b[1CSecurity\u001b[1CHeaders\u001b[22m\r\r\n\r\r\n\u001b[2CCache-Control:\u001b[1Cno-store\r\r\n\u001b[2CStrict-Transport-Security:\u001b[1Cmax-age=31536000\r\r\n\u001b[2CX-Content-Type-Options:\u001b[1Cnosniff\r\r\n\u001b[2CX-Frame-Options:\u001b[1CDENY\r\r\n\u001b[2CContent-Security-Policy:\u001b[1Cframe-ancestors\u001b[1C'none'\r\r\n\r\r\n\u001b[2C\u001b[1m4.\u001b[1COpenAPI\u001b[1CSpec\u001b[22m\r\r\n\r\r\n\u001b[2C-\u001b[1CPublish\u001b[1Cat\u001b[1C\u001b[38;2;177;185;249m/openapi.json\u001b[1C\u001b[39m(mandatory)\r\r\n\u001b[2C-\u001b[1CInclu"]
